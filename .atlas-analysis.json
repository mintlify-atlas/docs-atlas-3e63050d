  "keyFeatures": [
    "Real-time production tracking across print, diecut, rewind, and packaging operations",
    "Comprehensive inventory management for clichés, dies, ink, and finished goods",
    "Order management with work order (OT) tracking from intake to completion",
    "Quality control with incident reporting and tooling status monitoring",
    "Production planning and scheduling with visual calendar interface",
    "Multi-role support (Admin, Manager, Operator) with role-based permissions",
    "Audit logging for compliance and traceability",
    "Analytics dashboard with KPIs and production metrics",
    "Operator-friendly full-screen production reporting mode",
    "Excel import/export for data integration"
  ],
  "publicApiSurface": [
    "StateService - Global application state management",
    "OrdersService - Work order (OT) CRUD operations",
    "InventoryService - Cliché and die management",
    "AdminService - User, role, and machine administration",
    "AuditService - Audit log creation and retrieval",
    "QualityService - Incident reporting and tracking",
    "ExcelService - Excel import/export utilities",
    "OT interface - Work order data model",
    "CliseItem interface - Cliché inventory model",
    "DieItem interface - Die inventory model",
    "StockItem interface - Finished goods inventory model",
    "AppUser interface - User account model",
    "Machine interface - Production machine model",
    "AuditLog interface - Audit trail model"
  ]
}
